# ===== 基本设置 =====
set -g mouse on                      # 开启鼠标支持（滚动、点击、拖选）
set -g history-limit 50000           # 回滚缓冲区行数
set -g default-terminal "screen-256color"  # 256色支持
set -ga terminal-overrides ",xterm-256color:Tc"  # true color

# ===== 扩展按键（CSI u）：恢复 Shift+Enter 等组合键 =====
set -s extended-keys always                   # 无条件用 CSI u 形式转发给内层程序（tmux -> zsh）
set -as terminal-features 'xterm*:extkeys'    # 声明外层终端(iTerm2)能发送扩展按键(iTerm2 -> tmux)

# ===== 更好用的前缀键 =====
# 默认前缀是 Ctrl+b，可以改成 Ctrl+a（和 screen 一样，更顺手）
# set -g prefix C-a
# unbind C-b
# bind C-a send-prefix

# ===== 窗口和面板 =====
set -g base-index 1                  # 窗口编号从 1 开始
setw -g pane-base-index 1            # 面板编号从 1 开始
set -g renumber-windows on           # 关闭窗口后自动重编号

# ===== 分屏快捷键（更直观）=====
bind | split-window -h -c "#{pane_current_path}"   # | 水平分屏
bind - split-window -v -c "#{pane_current_path}"   # - 垂直分屏

# ===== 面板切换（Alt+方向键，无需前缀）=====
bind -n M-Left select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up select-pane -U
bind -n M-Down select-pane -D

# ===== 快速重载配置 =====
bind r source-file ~/.tmux.conf \; display "Config reloaded!"

# ===== 复制模式使用 vi 键位 =====
setw -g mode-keys vi

# ===== 减少 ESC 延迟（对 vim 用户很重要）=====
set -sg escape-time 10

# ===== 状态栏美化（可选）=====
set -g status-style 'bg=#333333 fg=#ffffff'
set -g status-left '[#S] '
set -g status-right '%H:%M %Y-%m-%d'
